-- Telekinesis Aura
function StartTelekinesisAura()
    if Connections.TelekinesisAura then
        Connections.TelekinesisAura:Disconnect()
        Connections.TelekinesisAura = nil
    end
    
    if not Settings.Aura.Telekinesis then return end
    
    local radius = Settings.Aura.Radius
    local bodies = {}
    
    Connections.TelekinesisAura = RunService.Heartbeat:Connect(function()
        if not Settings.Aura.Telekinesis then
            Connections.TelekinesisAura:Disconnect()
            Connections.TelekinesisAura = nil
            for _, bv in pairs(bodies) do
                if bv and bv.Parent then bv:Destroy() end
            end
            bodies = {}
            return
        end
        
        local char = LocalPlayer.Character
        if not char then return end
        
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character then
                local tRoot = player.Character:FindFirstChild("HumanoidRootPart")
                if tRoot then
                    local dist = (tRoot.Position - hrp.Position).Magnitude
                    if dist <= radius and not IsWhitelisted(player) then
                        local bv = bodies[player]
                        if not bv or not bv.Parent then
                            bv = Instance.new("BodyVelocity")
                            bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
                            bv.P = 10000
                            bv.Parent = tRoot
                            bodies[player] = bv
                        end
                        
                        local dir = (tRoot.Position - hrp.Position).Unit
                        bv.Velocity = dir * 100 + Vector3.new(0, 10, 0)
                        
                        pcall(function()
                            local grabEvents = ReplicatedStorage:FindFirstChild("GrabEvents")
                            if grabEvents then
                                local setOwner = grabEvents:FindFirstChild("SetNetworkOwner")
                                if setOwner then
                                    setOwner:FireServer(tRoot, tRoot.CFrame)
                                end
                            end
                        end)
                    else
                        if bodies[player] then
                            bodies[player]:Destroy()
                            bodies[player] = nil
                        end
                    end
                end
            end
        end
    end)
end

