-- ESP
function StartESP()
    if Connections.ESP then
        Connections.ESP:Disconnect()
        Connections.ESP = nil
    end
    
    if not Settings.Visual.ESP then
        -- Remove ESP existente
        for _, player in ipairs(Players:GetPlayers()) do
            if player.Character then
                local esp = player.Character:FindFirstChild("FTAP_ESP")
                if esp then esp:Destroy() end
            end
        end
        return    end
    
    local function AddESP(player)
        if player == LocalPlayer then return end
        if not player.Character then return end
        
        local char = player.Character
        if char:FindFirstChild("FTAP_ESP") then return end
        
        local highlight = Instance.new("Highlight")
        highlight.Name = "FTAP_ESP"
        highlight.FillColor = Color3.fromRGB(255, 0, 0)
        highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
        highlight.FillTransparency = 0.5
        highlight.OutlineTransparency = 0
        highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        highlight.Parent = char
    end
    
    -- Adiciona ESP para todos os jogadores
    for _, player in ipairs(Players:GetPlayers()) do
        AddESP(player)
    end
    
    -- Monitora novos jogadores
    Connections.ESP = Players.PlayerAdded:Connect(function(player)
        player.CharacterAdded:Connect(function()
            if Settings.Visual.ESP then
                AddESP(player)
            end
        end)
    end)
end

-- PCLD View
function StartPCLD()
    if Connections.PCLD then
        Connections.PCLD:Disconnect()
        Connections.PCLD = nil
    end
    
    if not Settings.Visual.PCLD then
        -- Remove PCLD existente
        for _, obj in ipairs(Workspace:GetDescendants()) do
            if obj.Name == "PlayerCharacterLocationDetector" and obj:IsA("BasePart") then
                obj.Transparency = 1
            end
        end
        return
    end
    
    Connections.PCLD = Workspace.DescendantAdded:Connect(function(obj)
        if obj:IsA("BasePart") and obj.Name == "PlayerCharacterLocationDetector" then
            obj.Transparency = 0.5
        end
    end)
    
    -- Aplica a todos existentes
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("BasePart") and obj.Name == "PlayerCharacterLocationDetector" then
            obj.Transparency = 0.5
        end
    end
end

