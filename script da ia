-- Anti Sticky
function StartAntiSticky()
    if not Settings.Anti.Sticky then
        local char = LocalPlayer.Character
        if char then
            for _, v in ipairs(char:GetChildren()) do
                if v:IsA("Part") or v:IsA("BasePart") then
                    v.CanTouch = true
                    v.CanQuery = true
                end
            end
        end
        return
    end
    
    local char = LocalPlayer.Character
    if char then
        for _, v in ipairs(char:GetChildren()) do
            if v:IsA("Part") or v:IsA("BasePart") then
                v.CanTouch = false
                v.CanQuery = false
            end
        end
    end
end

