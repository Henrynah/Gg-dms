-- Loop Kill
function StartLoopKill()
    if Connections.LoopKill then
        Connections.LoopKill:Disconnect()
        Connections.LoopKill = nil
    end
    
    if not Settings.Loop.Kill then return end
    
    local target = GetTargetPlayer(Settings.Loop.Target)
    if not target then return end
    
    Connections.LoopKill = RunService.Heartbeat:Connect(function()
        if not Settings.Loop.Kill or not target or not target.Parent then
            Connections.LoopKill:Disconnect()
            Connections.LoopKill = nil
            return
        end
        
        local tChar = target.Character
        if not tChar then return end
        
        local tRoot = tChar:FindFirstChild("HumanoidRootPart")
        local tHum = tChar:FindFirstChild("Humanoid")
        
        if tRoot and tHum and tHum.Health > 0 then
            local myChar = LocalPlayer.Character
            if myChar then
                local myRoot = myChar:FindFirstChild("HumanoidRootPart")
                if myRoot then
                    myRoot.CFrame = tRoot.CFrame * CFrame.new(0, 0, 3)
                    myRoot.AssemblyLinearVelocity = Vector3.zero
                end
            end
            
            -- Mata o alvo
            tHum.Health = 0
            
            -- Tenta pegar ownership
            local grabEvents = ReplicatedStorage:FindFirstChild("GrabEvents")
            if grabEvents then
                local setOwner = grabEvents:FindFirstChild("SetNetworkOwner")
                if setOwner then
                    pcall(function()
                        setOwner:FireServer(tRoot, tRoot.CFrame)
                    end)
                end
            end
            
            task.wait(0.2)
        end
    end)
end

-- Loop Kick (Grab + Blob)
function StartLoopKick()
    if Connections.LoopKick then
        Connections.LoopKick:Disconnect()
        Connections.LoopKick = nil
    end
    
    if not Settings.Loop.Kick then return end
    
    local target = GetTargetPlayer(Settings.Loop.Target)
    if not target then return end
    
    local char = LocalPlayer.Character
    local hum = char and char:FindFirstChild("Humanoid")
    local seat = hum and hum.SeatPart
    
    if not seat or not seat.Parent or seat.Parent.Name ~= "CreatureBlobman" then
        print("Você precisa estar em um Blobman para usar o Loop Kick!")
        Settings.Loop.Kick = false
        return
    end
    
    local blob = seat.Parent
    local scriptObj = blob:FindFirstChild("BlobmanSeatAndOwnerScript")
    local grab = scriptObj and scriptObj:FindFirstChild("CreatureGrab")
    local drop = scriptObj and scriptObj:FindFirstChild("CreatureDrop")
    local rightDet = blob:FindFirstChild("RightDetector")
    local rightWeld = rightDet and rightDet:FindFirstChild("RightWeld")
    local blobRoot = blob:FindFirstChild("HumanoidRootPart")
    
    if not (grab and drop and rightDet and rightWeld and blobRoot) then
        print("Blobman não está configurado corretamente!")
        Settings.Loop.Kick = false
        return
    end
    
    local savedPos = blobRoot.CFrame
    local packetTimer = 0
    
    Connections.LoopKick = RunService.Heartbeat:Connect(function()
        if not Settings.Loop.Kick or not target or not target.Parent then
            Connections.LoopKick:Disconnect()
            Connections.LoopKick = nil
            return
        end
        
        local tChar = target.Character
        if not tChar then return end
        
        local tRoot = tChar:FindFirstChild("HumanoidRootPart")
        local tHum = tChar:FindFirstChild("Humanoid")
        
        if tRoot and tHum and tHum.Health > 0 and blobRoot then
            blobRoot.CFrame = savedPos
            blobRoot.Velocity = Vector3.zero
            
            local lockPos = savedPos * CFrame.new(0, 23, 0)
            tRoot.CFrame = lockPos
            tRoot.Velocity = Vector3.zero
            tRoot.RotVelocity = Vector3.zero
            
            if tick() - packetTimer > 0.012 then
                packetTimer = tick()
                pcall(function()
                    tHum.PlatformStand = true
                    tHum.Sit = true
                    
                    local grabEvents = ReplicatedStorage:FindFirstChild("GrabEvents")
                    if grabEvents then
                        local setOwner = grabEvents:FindFirstChild("SetNetworkOwner")
                        local destroyLine = grabEvents:FindFirstChild("DestroyGrabLine")
                        local createLine = grabEvents:FindFirstChild("CreateGrabLine")
                        
                        if setOwner then setOwner:FireServer(tRoot, lockPos) end
                        if destroyLine then destroyLine:FireServer(tRoot) end
                        if createLine then createLine:FireServer(tRoot, Vector3.zero, tRoot.Position, false) end
                    end
                    
                    if rightWeld then
                        drop:FireServer(rightWeld)
                        grab:FireServer(rightDet, tRoot, rightWeld)
                    end
                end)
            end
        end
    end)
end

