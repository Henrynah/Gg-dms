-- ============================================================

function SpawnBlobman()
    local char = LocalPlayer.Character
    if not char then return end
    
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    SpawnToy("CreatureBlobman", hrp.CFrame * CFrame.new(0, 5, 5))
    
    local toysFolder = Workspace:FindFirstChild(LocalPlayer.Name .. "SpawnedInToys")
    if toysFolder then
        local blob = toysFolder:FindFirstChild("CreatureBlobman")
        if blob then
            BlobmanInstance = blob
        end
    end
end

function SitOnBlobman()
    if not BlobmanInstance then
        SpawnBlobman()
        task.wait(0.5)
    end
    
    if not BlobmanInstance then return end
    
    local seat = BlobmanInstance:FindFirstChild("VehicleSeat")
    if not seat then return end
    
    local char = LocalPlayer.Character
    if not char then return end
    
    local hum = char:FindFirstChild("Humanoid")
    if not hum then return end
    
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if hrp then
        hrp.CFrame = seat.CFrame + Vector3.new(0, 2, 0)
        hrp.AssemblyLinearVelocity = Vector3.zero
    end
    
    seat:Sit(hum)
end

function BlobmanKickAll()
    if not BlobmanInstance then
        SpawnBlobman()
        task.wait(0.5)
    end
    
    if not BlobmanInstance then return end
    
    local scriptObj = BlobmanInstance:FindFirstChild("BlobmanSeatAndOwnerScript")
    local grab = scriptObj and scriptObj:FindFirstChild("CreatureGrab")
    local drop = scriptObj and scriptObj:FindFirstChild("CreatureDrop")
    local rightDet = BlobmanInstance:FindFirstChild("RightDetector")
    local rightWeld = rightDet and rightDet:FindFirstChild("RightWeld")
    local blobRoot = BlobmanInstance:FindFirstChild("HumanoidRootPart")
    
    if not (grab and drop and rightDet and rightWeld and blobRoot) then
        print("Blobman não está configurado corretamente!")
        return
    end
    
    local savedPos = blobRoot.CFrame
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and not IsWhitelisted(player) then
            local tChar = player.Character
            if tChar then
                local tRoot = tChar:FindFirstChild("HumanoidRootPart")
                if tRoot then
                    pcall(function()
                        blobRoot.CFrame = tRoot.CFrame
                        task.wait(0.1)
                        
                        local grabEvents = ReplicatedStorage:FindFirstChild("GrabEvents")
                        if grabEvents then
                            local setOwner = grabEvents:FindFirstChild("SetNetworkOwner")
                            local destroyLine = grabEvents:FindFirstChild("DestroyGrabLine")
                            
                            if setOwner then setOwner:FireServer(tRoot, tRoot.CFrame) end
                            if destroyLine then destroyLine:FireServer(tRoot) end
                        end
                        
                        grab:FireServer(rightDet, tRoot, rightWeld)
                        task.wait(0.1)
                        drop:FireServer(rightWeld)
                        task.wait(0.1)
                        
                        tRoot.CFrame = savedPos * CFrame.new(0, 50, 0)
                        tRoot.AssemblyLinearVelocity = Vector3.zero
                    end)
                end
            end
            task.wait(0.2)
        end
    end
    
    blobRoot.CFrame = savedPos
end

