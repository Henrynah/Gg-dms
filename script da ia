-- Water Walk
function StartWaterWalk()
    local oceanModel = Workspace:FindFirstChild("Map") 
        and Workspace.Map:FindFirstChild("AlwaysHereTweenedObjects") 
        and Workspace.Map.AlwaysHereTweenedObjects:FindFirstChild("Ocean") 
        and Workspace.Map.AlwaysHereTweenedObjects.Ocean:FindFirstChild("Object") 
        and Workspace.Map.AlwaysHereTweenedObjects.Ocean.Object:FindFirstChild("ObjectModel")
    
    if oceanModel then
        for _, part in ipairs(oceanModel:GetChildren()) do
            if part:IsA("BasePart") then
                part.CanCollide = Settings.Misc.WaterWalk
            end
        end
    end
end

-- Infinite Jump
function StartInfiniteJump()
    if Connections.InfiniteJump then
        Connections.InfiniteJump:Disconnect()
        Connections.InfiniteJump = nil
    end
    
    if not Settings.Misc.InfiniteJump then return end
    
    Connections.InfiniteJump = UserInputService.JumpRequest:Connect(function()
        local char = LocalPlayer.Character
        if char then
            local hum = char:FindFirstChild("Humanoid")
            if hum then
                hum:ChangeState(Enum.HumanoidStateType.Jumping)
            end
        end
    end)
end

-- Packet Lag
function StartPacketLag()
    if Connections.PacketLag then
        Connections.PacketLag:Disconnect()
        Connections.PacketLag = nil
    end
    
    if not Settings.Misc.PacketLag then return end
    
    local extendGrabLine = ReplicatedStorage:FindFirstChild("GrabEvents") 
        and ReplicatedStorage.GrabEvents:FindFirstChild("ExtendGrabLine")
    
    if not extendGrabLine then return end
    
    Connections.PacketLag = RunService.Heartbeat:Connect(function()
        if not Settings.Misc.PacketLag then
            Connections.PacketLag:Disconnect()
            Connections.PacketLag = nil
            return
        end
        
        pcall(function()
            extendGrabLine:FireServer(string.rep("FTAP ULTRA HUB", 5000))
        end)
    end)
end

