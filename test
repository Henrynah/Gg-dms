-- ============================================================
local function getname(v)
    if not v then return "" end
    local match = string.match(v, "%((.-)%)")
    return match or v
end

local function sno(obj)
    if obj and obj.Parent then
        pcall(function() SetNetworkOwner:FireServer(obj, obj.CFrame) end)
    end
end

local function stvel(hrp)
    if hrp and hrp.Parent then
        hrp.AssemblyLinearVelocity = Vector3.zero
        hrp.AssemblyAngularVelocity = Vector3.zero
    end
end

local function isnetworkowner(part)
    return part and part:IsDescendantOf(Workspace) and part:GetNetworkOwner() == LocalPlayer
end

local function FWC(parent, name, time)
    return parent:FindFirstChild(name) or parent:WaitForChild(name, time or 3)
end

local function getPlayerFromSelection(selection)
    if not selection or selection == "" then return nil end
    local username = string.match(selection, "%((.-)%)")
    if username then
        return Players:FindFirstChild(username)
    end
    return nil
end

local function getPlayerList()
    local list = {}
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            table.insert(list, plr.DisplayName .. " (@" .. plr.Name .. ")")
        end
    end
    return list
end

local function getPlayerNames()
    local list = {}
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            table.insert(list, plr.Name)
        end
    end
    return list
end

local function findPlayerByPartialName(partial)
    partial = string.lower(partial)
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local nameLower = string.lower(player.Name)
            local displayLower = string.lower(player.DisplayName or "")
            if string.find(nameLower, partial, 1, true) or string.find(displayLower, partial, 1, true) then
                return player
            end
        end
    end
    return nil
end

