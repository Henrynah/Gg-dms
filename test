local function GetBlobman()
    local char = plr.Character
    local hum = char and char:FindFirstChild("Humanoid")
    
    if hum and hum.SeatPart then
        local seatParent = hum.SeatPart.Parent
        if seatParent and seatParent.Name == "CreatureBlobman" then
            return seatParent
        end
    end
    
    local folder = workspace:FindFirstChild(plr.Name .. "SpawnedInToys")
    if folder then
        local blob = folder:FindFirstChild("CreatureBlobman")
        if blob then
            return blob
        end
    end
    
    return nil
end

local function SitOnBlobman(blobman)
    if not blobman then return false end
    
    local char = plr.Character
    local hum = char and char:FindFirstChild("Humanoid")
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    
    if not hum or not hrp then return false end
    
    local seat = blobman:FindFirstChild("VehicleSeat")
    if not seat then return false end
    
    if hum.SeatPart == seat then return true end
    
    hrp.CFrame = seat.CFrame + Vector3.new(0, 2, 0)
    hrp.AssemblyLinearVelocity = Vector3.zero
    seat:Sit(hum)
    
    local t = tick()
    repeat
        RunService.Heartbeat:Wait()
    until hum.SeatPart == seat or tick() - t > 2
    
    return hum.SeatPart == seat
end

local function StartLoopKickBlob()
    if loopKickBlobTask then
        task.cancel(loopKickBlobTask)
        loopKickBlobTask = nil
    end
    
    local targetName = LoopConfig.LoopKickBlobTarget
    if not targetName or targetName == "None" then return end
    
    local target = Players:FindFirstChild(targetName)
    if not target then return end
    
    loopKickBlobTask = task.spawn(function()
        local RS = rs
        local GE = RS:WaitForChild("GrabEvents")
        
        local blobman = GetBlobman()
        
        if not blobman then
            local hrp = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                pcall(function()
                    RS.MenuToys.SpawnToyRemoteFunction:InvokeServer(
                        "CreatureBlobman",
                        hrp.CFrame * CFrame.new(0, 5, 5),
                        Vector3.zero
                    )
                end)
                
                local t = tick()
                repeat
                    RunService.Heartbeat:Wait()
                    blobman = GetBlobman()
                until blobman or tick() - t > 5
            end
        end
        
        if not blobman then return end
        
        if LoopConfig.LoopKickBlobAutoSit then
            SitOnBlobman(blobman)
        end
        
        local hum = plr.Character and plr.Character:FindFirstChild("Humanoid")
        if not hum or not hum.SeatPart or hum.SeatPart.Parent ~= blobman then return end
        
        local blobRoot = blobman:FindFirstChild("HumanoidRootPart") or blobman.PrimaryPart
        local scriptObj = blobman:FindFirstChild("BlobmanSeatAndOwnerScript")
        local CG = scriptObj and scriptObj:FindFirstChild("CreatureGrab")
        local CD = scriptObj and scriptObj:FindFirstChild("CreatureDrop")
        
        local L_Det = blobman:FindFirstChild("LeftDetector")
        local R_Det = blobman:FindFirstChild("RightDetector")
        local L_Weld = L_Det and (L_Det:FindFirstChild("LeftWeld") or L_Det:FindFirstChildWhichIsA("Weld"))
        local R_Weld = R_Det and (R_Det:FindFirstChild("RightWeld") or R_Det:FindFirstChildWhichIsA("Weld"))
        
        if not (blobRoot and CG and CD and L_Det and R_Det and L_Weld and R_Weld) then return end
        
        local SavedPos = blobRoot.CFrame
        local packetTimer = 0
        
        local tChar = target.Character
        local tRoot = tChar and tChar:FindFirstChild("HumanoidRootPart")
        
        if tRoot and blobRoot then
            local bringStart = tick()
            while tick() - bringStart < 0.35 do
                if not LoopConfig.LoopKickBlobEnabled then break end
                
                blobRoot.CFrame = tRoot.CFrame
                blobRoot.Velocity = Vector3.zero
                
                pcall(function()
                    if CG and R_Det then
                        CG:FireServer(R_Det, tRoot, R_Weld)
                    end
                    GE.CreateGrabLine:FireServer(tRoot, Vector3.zero, tRoot.Position, false)
                    GE.SetNetworkOwner:FireServer(tRoot, blobRoot.CFrame)
                end)
                RunService.Heartbeat:Wait()
            end
            
            blobRoot.CFrame = SavedPos
            blobRoot.Velocity = Vector3.zero
            task.wait(0.05)
        end
        
        while LoopConfig.LoopKickBlobEnabled do
            target = Players:FindFirstChild(targetName)
            if not target or not target.Parent or not target.Character then break end
            
            if LoopConfig.LoopKickBlobWhitelist and IsFriend(target) then
                task.wait(0.5)
                continue
            end
            
            tChar = target.Character
            tRoot = tChar and tChar:FindFirstChild("HumanoidRootPart")
            local tHum = tChar and tChar:FindFirstChild("Humanoid")
            
            if tRoot and tHum and tHum.Health > 0 and blobRoot then
                blobRoot.CFrame = SavedPos
                blobRoot.Velocity = Vector3.zero
                
                local lockPos = SavedPos * CFrame.new(0, LoopConfig.LoopKickBlobHeight, 0)
                tRoot.CFrame = lockPos
                tRoot.Velocity = Vector3.zero
                tRoot.RotVelocity = Vector3.zero
                
                if tick() - packetTimer > LoopConfig.LoopKickBlobDelay then
                    packetTimer = tick()
                    
                    pcall(function()
                        tHum.PlatformStand = true
                        tHum.Sit = true
                        
                        GE.SetNetworkOwner:FireServer(tRoot, lockPos)
                        
                        if LoopConfig.LoopKickBlobUseBothHands then
                            if L_Weld then
                                CD:FireServer(L_Weld)
                                CG:FireServer(L_Det, tRoot, L_Weld)
                            end
                            if R_Weld then
                                CD:FireServer(R_Weld)
                                CG:FireServer(R_Det, tRoot, R_Weld)
                            end
                        else
                            if R_Weld then
                                CD:FireServer(R_Weld)
                                CG:FireServer(R_Det, tRoot, R_Weld)
                            end
                        end
                        
                        GE.DestroyGrabLine:FireServer(tRoot)
                        GE.CreateGrabLine:FireServer(tRoot, Vector3.zero, tRoot.Position, false)
                    end)
                end
            else
                blobRoot.CFrame = SavedPos
                blobRoot.Velocity = Vector3.zero
            end
            
            if not LoopConfig.LoopKickBlobEnabled then break end
            RunService.Heartbeat:Wait()
        end
        
        if blobRoot then
            blobRoot.CFrame = SavedPos
            blobRoot.Velocity = Vector3.zero
        end
        
        LoopConfig.LoopKickBlobEnabled = false
    end)
end

local function StopLoopKickBlob()
    LoopConfig.LoopKickBlobEnabled = false
    if loopKickBlobTask then
        task.cancel(loopKickBlobTask)
        loopKickBlobTask = nil
    end
end

