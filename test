-- ============================================================
-- LOOP KICK PRINCIPAL (GRAB + BLOB) - VERSÃO OTIMIZADA
-- ============================================================
local kickLoopEnabled = false
local kickLoopConnection = nil
local loopKickDualActive = false
local loopKickTask = nil
local _G = getgenv() or _G

local function createKickLoop()
    if kickLoopConnection then
        kickLoopConnection:Disconnect()
        kickLoopConnection = nil
    end
    
    kickLoopConnection = RunService.Heartbeat:Connect(function()
        if not kickLoopEnabled then 
            kickLoopConnection:Disconnect()
            kickLoopConnection = nil
            return 
        end
        
        local target = SelectedPlayer
        if not target or not target.Parent then 
            kickLoopEnabled = false
            if kickLoopConnection then 
                kickLoopConnection:Disconnect()
                kickLoopConnection = nil
            end
            return 
        end
        
        local myChar = LocalPlayer.Character
        if not myChar then return end
        
        local myRoot = myChar:FindFirstChild("HumanoidRootPart")
        if not myRoot then return end
        
        local myHum = myChar:FindFirstChild("Humanoid")
        if not myHum then return end
        
        local tChar = target.Character
        if not tChar then return end
        
        local tRoot = tChar:FindFirstChild("HumanoidRootPart")
        local tHum = tChar:FindFirstChild("Humanoid")
        
        if not tRoot or not tHum or tHum.Health <= 0 then return end
        
        local seat = myHum.SeatPart
        local savedPos = myRoot.CFrame
        local dragging = false
        local grabStartTime = 0
        
        tRoot.AssemblyLinearVelocity = Vector3.zero
        tRoot.AssemblyAngularVelocity = Vector3.zero
        tRoot.Velocity = Vector3.zero
        
        -- BLOBMAN SPAM (Dual Hand)
        if seat then
            local blobman = seat.Parent
            if blobman and blobman.Name == "CreatureBlobman" then
                local remoteFolder = blobman:FindFirstChild("BlobmanSeatAndOwnerScript")
                if remoteFolder then
                    local grab = remoteFolder:FindFirstChild("CreatureGrab")
                    local drop = remoteFolder:FindFirstChild("CreatureDrop")
                    
                    local L_Det = blobman:FindFirstChild("LeftDetector")
                    local R_Det = blobman:FindFirstChild("RightDetector")
                    local L_Weld = L_Det and (L_Det:FindFirstChild("LeftWeld") or L_Det:FindFirstChild("RigidConstraint"))
                    local R_Weld = R_Det and (R_Det:FindFirstChild("RightWeld") or R_Det:FindFirstChild("RigidConstraint"))
                    
                    if grab and drop and L_Weld and R_Weld then
                        pcall(function()
                            grab:FireServer(L_Det, tRoot, L_Weld)
                            grab:FireServer(R_Det, tRoot, R_Weld)
                            task.wait(0.03)
                            drop:FireServer(L_Weld, tRoot)
                            drop:FireServer(R_Weld, tRoot)
                            task.wait(0.02)
                            grab:FireServer(L_Det, tRoot, L_Weld)
                            grab:FireServer(R_Det, tRoot, R_Weld)
                            task.wait(0.02)
                            drop:FireServer(L_Weld, tRoot)
                            drop:FireServer(R_Weld, tRoot)
                        end)
                    end
                end
            end
        end
        
        -- POSITIONING LOGIC (High Kick)
        if not dragging then
            myRoot.CFrame = tRoot.CFrame
            myRoot.Velocity = Vector3.zero
            
            pcall(function()
                tHum.PlatformStand = true
                tHum.Sit = true
                SetNetworkOwner:FireServer(tRoot, myRoot.CFrame)
                CreateGrabLine:FireServer(tRoot, Vector3.zero, tRoot.Position, false)
            end)
            
            if grabStartTime == 0 then grabStartTime = tick() end
            if tick() - grabStartTime > 0.3 then
                dragging = true
                grabStartTime = 0
            end
        else
            myRoot.CFrame = savedPos
            myRoot.Velocity = Vector3.zero
            
            local lockPos = savedPos * CFrame.new(0, customKickHeight, 0)
            tRoot.CFrame = lockPos
            tRoot.Velocity = Vector3.zero
            tRoot.RotVelocity = Vector3.zero
            
            pcall(function()
                tHum.PlatformStand = true
                tHum.Sit = false
                SetNetworkOwner:FireServer(tRoot, lockPos)
                DestroyGrabLine:FireServer(tRoot)
                CreateGrabLine:FireServer(tRoot, Vector3.zero, tRoot.Position, false)
            end)
        end
    end)
end

local function startKickLoop(targetName, height)
    if not targetName then return false end
    
    local target = Players:FindFirstChild(targetName)
    if not target then return false end
    
    SelectedPlayer = target
    if height then customKickHeight = height end
    
    kickLoopEnabled = true
    createKickLoop()
    return true
end

local function stopKickLoop()
    kickLoopEnabled = false
    if kickLoopConnection then
        kickLoopConnection:Disconnect()
        kickLoopConnection = nil
    end
    if loopKickTask then
        task.cancel(loopKickTask)
        loopKickTask = nil
    end
    loopKickDualActive = false
end

local function startDualKickLoop(targetName, height)
    if not targetName then return false
    
    local target = Players:FindFirstChild(targetName)
    if not target then return false
    
    SelectedPlayer = target
    if height then customKickHeight = height end
    
    loopKickDualActive = true
    startKickLoop(targetName, height)
    return true
end

