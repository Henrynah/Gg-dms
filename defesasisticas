function AntiSystem:StopAll()
    for name, conn in pairs(self.connections) do
        if type(conn) == "table" then
            for _, c in ipairs(conn) do
                if c and c.Disconnect then c:Disconnect() end
            end
        elseif conn and conn.Disconnect then
            conn:Disconnect()
        end
        self.connections[name] = nil
    end

    for name, task in pairs(self.tasks) do
        if task then
            task.cancel(task)
        end
        self.tasks[name] = nil
    end

    -- Restaurar estado do Anti-Lag
    local playerScripts = LocalPlayer:FindFirstChild("PlayerScripts")
    local beamScript = playerScripts and playerScripts:FindFirstChild("CharacterAndBeamMove")
    if beamScript then
        beamScript.Disabled = false
    end

    -- Restaurar Anti-Sticky
    local stickyScript = playerScripts and playerScripts:FindFirstChild("StickyPartsTouchDetection")
    if stickyScript then
        stickyScript.Disabled = false
    end

    notify("Anti System", "Todas as proteções foram desativadas.", 3)
end

