-- 1. ANTI GRAB V1 (BÁSICO)
-- ============================================================
local function StartAntiGrab()
    if Config.AntiGrabEnabled then return end
    Config.AntiGrabEnabled = true
    
    AGConnections["AntiGrab"] = RunService.Heartbeat:Connect(function()
        if not Config.AntiGrabEnabled then return end
        
        local character = GetCharacter()
        if character and character:FindFirstChild("Head") then
            local head = character.Head
            
            if head:FindFirstChild("PartOwner") then
                task.spawn(function()
                    -- Luta contra o grab
                    StruggleFire()
                    StopVelocity()
                    
                    -- Ancora todas as partes
                    for _, part in pairs(character:GetChildren()) do
                        if part:IsA("BasePart") then
                            part.Anchored = true
                        end
                    end
                    
                    -- Espera ser solto
                    while isHeld and isHeld.Value do
                        task.wait()
                    end
                    
                    -- Desancora
                    for _, part in pairs(character:GetChildren()) do
                        if part:IsA("BasePart") then
                            part.Anchored = false
                        end
                    end
                end)
            end
        end
    end)
end

local function StopAntiGrab()
    Config.AntiGrabEnabled = false
    Disc("AntiGrab")
    AnchorCharacter(false)
end

-- ============================================================
-- 2. ANTI GRAB V2 (DEFESA COMPLETA)
-- ============================================================
local function StartAntiGrabV2()
    if Config.AntiGrabV2Enabled then return end
    Config.AntiGrabV2Enabled = true
    
    AGConnections["AntiGrabV2"] = isHeld:GetPropertyChangedSignal("Value"):Connect(function()
        if not Config.AntiGrabV2Enabled or not isHeld.Value then return end
        
        local Char = GetCharacter()
        if not Char then return end
        
        local Root = GetHumanoidRootPart()
        local Hum = GetHumanoid()
        local Head = GetHead()
        local lastFreePos = Root and Root.CFrame
        
        if not Root or not Hum then return end
        
        -- Desativa colisão
        for _, part in pairs(Char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
            end
        end
        
        -- Luta contínua
        task.spawn(function()
            while Config.AntiGrabV2Enabled and isHeld.Value do
                StruggleFire()
                RagdollFire(Root, 0)
                StopVelocity()
                task.wait()
            end
        end)
        
        -- Ancora e trava posição
        task.spawn(function()
            while Config.AntiGrabV2Enabled and isHeld.Value do
                Hum.Sit = false
                Hum:ChangeState(Enum.HumanoidStateType.GettingUp)
                Hum:SetStateEnabled(Enum.HumanoidStateType.Jumping, true)
                Root.Anchored = true
                Root.AssemblyLinearVelocity = Vector3.zero
                Root.AssemblyAngularVelocity = Vector3.zero
                task.wait()
            end
            if Root then Root.Anchored = false end
        end)
        
        -- Movimento durante grab
        task.spawn(function()
            while Config.AntiGrabV2Enabled and Root and Root.Anchored do
                if Hum and Hum.MoveDirection.Magnitude > 0 then
                    Root.CFrame = Root.CFrame + (Hum.MoveDirection * 0.2)
                    lastFreePos = Root.CFrame
                end
                if Head then
                    Head.CanCollide = false
                    Head.AssemblyLinearVelocity = Vector3.zero
                    Head.AssemblyAngularVelocity = Vector3.zero
                end
                task.wait()
            end
        end)
        
        -- Renderizador para manter posição
        local renderConn = RunService.RenderStepped:Connect(function()
            if not Config.AntiGrabV2Enabled or not isHeld.Value then
                renderConn:Disconnect()
                return
            end
            if Root and lastFreePos then
                Root.CFrame = lastFreePos
                Root.AssemblyLinearVelocity = Vector3.zero
                Root.AssemblyAngularVelocity = Vector3.zero
            end
        end)
        
        AGConnections["AntiGrabV2Render"] = renderConn
    end)
    
    -- Se já estiver segurado
    if isHeld.Value then
        AGConnections["AntiGrabV2"]:Fire()
    end
end

local function StopAntiGrabV2()
    Config.AntiGrabV2Enabled = false
    Disc("AntiGrabV2")
    Disc("AntiGrabV2Render")
    AnchorCharacter(false)
    
    local char = GetCharacter()
    if char then
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = true
            end
        end
    end
end

