-- ============================================================
local function Disc(name)
    if AGConnections[name] then
        AGConnections[name]:Disconnect()
        AGConnections[name] = nil
    end
end

local function CancelTask(name)
    if Tasks[name] then
        task.cancel(Tasks[name])
        Tasks[name] = nil
    end
end

local function Notify(title, content, duration)
    print(string.format("[%s] %s", title or "AntiGrab", content or ""))
end

local function GetCharacter()
    return LocalPlayer.Character
end

local function GetHumanoidRootPart()
    local char = GetCharacter()
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function GetHumanoid()
    local char = GetCharacter()
    return char and char:FindFirstChildOfClass("Humanoid")
end

local function GetHead()
    local char = GetCharacter()
    return char and char:FindFirstChild("Head")
end

local function GetToysFolder()
    return Workspace:FindFirstChild(LocalPlayer.Name .. "SpawnedInToys")
end

local function GetPlot()
    for i = 1, 5 do
        local plot = Workspace.Plots:FindFirstChild("Plot" .. i)
        if plot then
            local sign = plot:FindFirstChild("PlotSign")
            if sign then
                local owners = sign:FindFirstChild("ThisPlotsOwners")
                if owners then
                    for _, v in pairs(owners:GetChildren()) do
                        if v:IsA("StringValue") and v.Value == LocalPlayer.Name then
                            return plot
                        end
                    end
                end
            end
        end
    end
    return nil
end

local function IsInPlot()
    local plot = GetPlot()
    return plot ~= nil
end

local function IsInOwnedPlot()
    local plot = GetPlot()
    if not plot then return false end
    local sign = plot:FindFirstChild("PlotSign")
    if not sign then return false end
    local owners = sign:FindFirstChild("ThisPlotsOwners")
    if not owners then return false end
    for _, v in pairs(owners:GetChildren()) do
        if v:IsA("StringValue") and v.Value == LocalPlayer.Name then
            return true
        end
    end
    return false
end

local function AnchorCharacter(anchor)
    local char = GetCharacter()
    if not char then return end
    
    for _, part in pairs(char:GetChildren()) do
        if part:IsA("BasePart") then
            part.Anchored = anchor
        end
    end
    
    if anchor then
        local hrp = GetHumanoidRootPart()
        if hrp then
            hrp.AssemblyLinearVelocity = Vector3.zero
            hrp.AssemblyAngularVelocity = Vector3.zero
        end
    end
end

