-- 3. ANTI GRAB V3 (COM TELEPORTE)
-- ============================================================
local function SavePosition()
    local hrp = GetHumanoidRootPart()
    if hrp then
        savedCFrame = hrp.CFrame
        savedPosition = hrp.Position
        if not originalPosition then
            originalPosition = hrp.CFrame
        end
        return true
    end
    return false
end

local function TeleportToPosition(cframe, effectColor)
    if isTeleporting then return end
    isTeleporting = true
    
    local hrp = GetHumanoidRootPart()
    if hrp and cframe then
        local char = GetCharacter()
        if char then
            -- Efeito de partículas
            local attachment = Instance.new("Attachment")
            attachment.Parent = hrp
            
            local particle = Instance.new("ParticleEmitter")
            particle.Parent = attachment
            particle.Texture = "rbxassetid://243098098"
            particle.Color = ColorSequence.new(effectColor or Color3.fromRGB(130, 0, 255), 
                                              Color3.fromRGB(80, 0, 180))
            particle.Size = NumberSequence.new(0.6, 0.1)
            particle.Lifetime = NumberRange.new(0.5, 1)
            particle.Rate = 200
            particle.Speed = NumberRange.new(2, 7)
            particle.SpreadAngle = Vector2.new(60, 60)
            particle.Transparency = NumberSequence.new(0.3, 1)
            particle.Acceleration = Vector3.new(0, 3, 0)
            
            particle:Emit(40)
            task.wait(0.1)
            
            hrp.CFrame = cframe
            hrp.AssemblyLinearVelocity = Vector3.zero
            hrp.AssemblyAngularVelocity = Vector3.zero
            
            particle:Emit(30)
            task.wait(0.2)
            particle:Destroy()
            attachment:Destroy()
        else
            hrp.CFrame = cframe
            hrp.AssemblyLinearVelocity = Vector3.zero
            hrp.AssemblyAngularVelocity = Vector3.zero
        end
    end
    isTeleporting = false
end

local function TeleportToSaved()
    if savedCFrame then
        TeleportToPosition(savedCFrame, Color3.fromRGB(130, 0, 255))
    end
end

local function TeleportToOriginal()
    if originalPosition then
        TeleportToPosition(originalPosition, Color3.fromRGB(0, 200, 255))
    end
end

local function StartAntiGrabV3()
    if Config.AntiGrabV3Enabled then return end
    Config.AntiGrabV3Enabled = true
    
    task.wait(0.5)
    SavePosition()
    
    AGConnections["AntiGrabV3"] = isHeld:GetPropertyChangedSignal("Value"):Connect(function()
        if not Config.AntiGrabV3Enabled or not isHeld.Value then return end
        
        local char = GetCharacter()
        local hrp = GetHumanoidRootPart()
        local hum = GetHumanoid()
        
        if not char or not hrp or not hum then return end
        
        if Config.SavePositionOnSpawn and not originalPosition then
            originalPosition = hrp.CFrame
            savedCFrame = hrp.CFrame
            savedPosition = hrp.Position
        end
        
        grabCount = grabCount + 1
        lastGrabTime = tick()
        
        if Config.StruggleOnGrab then
            StruggleFire()
        end
        
        StopVelocity()
        
        if Config.AnchorOnGrab then
            AnchorCharacter(true)
        end
        
        if Config.TeleportOnMultipleGrabs and grabCount >= Config.MaxGrabsBeforeTeleport then
            task.spawn(function()
                task.wait(0.1)
                if Config.ReturnToOriginalPos and originalPosition then
                    TeleportToOriginal()
                elseif savedCFrame then
                    TeleportToSaved()
                end
                grabCount = 0
                AnchorCharacter(false)
            end)
            return
        end
        
        if Config.FreezePosition and savedCFrame then
            task.spawn(function()
                while Config.AntiGrabV3Enabled and isHeld.Value do
                    if hrp then
                        hrp.CFrame = savedCFrame
                        hrp.AssemblyLinearVelocity = Vector3.zero
                        hrp.AssemblyAngularVelocity = Vector3.zero
                    end
                    task.wait()
                end
                AnchorCharacter(false)
            end)
        end
        
        task.spawn(function()
            while Config.AntiGrabV3Enabled and isHeld.Value do
                if Config.StruggleOnGrab then
                    StruggleFire()
                end
                task.wait(0.05)
            end
            AnchorCharacter(false)
            if tick() - lastGrabTime > 5 then
                grabCount = 0
            end
        end)
    end)
    
    -- Monitora PartOwner na cabeça
    AGConnections["AntiGrabV3PartOwner"] = RunService.Heartbeat:Connect(function()
        if not Config.AntiGrabV3Enabled then return end
        local head = GetHead()
        if head and head:FindFirstChild("PartOwner") and not isHeld.Value then
            -- Força luta se tiver PartOwner mas IsHeld for falso
            if Config.StruggleOnGrab then
                StruggleFire()
            end
        end
    end)
    
    -- Monitora quando o personagem respawna
    AGConnections["AntiGrabV3Char"] = LocalPlayer.CharacterAdded:Connect(function()
        task.wait(1)
        originalPosition = nil
        savedCFrame = nil
        savedPosition = nil
        grabCount = 0
        SavePosition()
    end)
    
    if isHeld.Value then
        AGConnections["AntiGrabV3"]:Fire()
    end
end

local function StopAntiGrabV3()
    Config.AntiGrabV3Enabled = false
    Disc("AntiGrabV3")
    Disc("AntiGrabV3PartOwner")
    Disc("AntiGrabV3Char")
    AnchorCharacter(false)
    grabCount = 0
    isTeleporting = false
end

