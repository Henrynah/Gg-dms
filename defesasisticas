-- Anti-Grab v1 (Básico)
local function StartAntiGrabV1()
    if not Anti.AntiGrab then return end

    local conn
    conn = BeingHeld.Changed:Connect(function(held)
        if held and Anti.AntiGrab then
            local char = GetCharacter()
            local hrp = GetHRP()
            local hum = GetHumanoid()

            if hrp then hrp.Anchored = true end
            if Struggle then Struggle:FireServer(LocalPlayer) end
            if RagdollRemote and hrp then RagdollRemote:FireServer(hrp, 0) end

            task.spawn(function()
                while BeingHeld.Value and Anti.AntiGrab do
                    if Struggle then Struggle:FireServer(LocalPlayer) end
                    task.wait()
                end
                if hrp then hrp.Anchored = false end
            end)
        end
    end)
    return conn
end

-- Anti-Grab v2 (Full Defense)
local function StartAntiGrabV2()
    if not Anti.AntiGrabV2 then return end

    local conn
    conn = BeingHeld:GetPropertyChangedSignal("Value"):Connect(function()
        if not Anti.AntiGrabV2 or not BeingHeld.Value then return end

        local char = GetCharacter()
        local hrp = GetHRP()
        local hum = GetHumanoid()
        local head = char and char:FindFirstChild("Head")

        if not (char and hrp and hum) then return end

        -- Desativa colisões
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide = false end
        end

        -- Loop de luta
        task.spawn(function()
            while Anti.AntiGrabV2 and BeingHeld.Value do
                pcall(function()
                    if Struggle then Struggle:FireServer() end
                    if RagdollRemote and hrp then RagdollRemote:FireServer(hrp, 0) end
                    if StopAllVelocity then StopAllVelocity:FireServer() end
                end)
                task.wait()
            end
        end)

        -- Loop de física
        task.spawn(function()
            while Anti.AntiGrabV2 and BeingHeld.Value do
                pcall(function()
                    if hum then
                        hum.Sit = false
                        hum:ChangeState(Enum.HumanoidStateType.GettingUp)
                        hum:SetStateEnabled(Enum.HumanoidStateType.Jumping, true)
                    end
                    if hrp then
                        hrp.Anchored = true
                        hrp.AssemblyLinearVelocity = Vector3.zero
                        hrp.AssemblyAngularVelocity = Vector3.zero
                    end
                end)
                task.wait()
            end
            if hrp then hrp.Anchored = false end
        end)

        -- Loop de movimento (Anti-Grab V3 style)
        task.spawn(function()
            local lastFreePos = hrp and hrp.CFrame
            while Anti.AntiGrabV2 and BeingHeld.Value do
                pcall(function()
                    if hum and hum.MoveDirection.Magnitude > 0 and hrp then
                        hrp.CFrame = hrp.CFrame + (hum.MoveDirection * 0.43)
                        lastFreePos = hrp.CFrame
                    end
                    if head then
                        head.CanCollide = false
                        head.AssemblyLinearVelocity = Vector3.zero
                        head.AssemblyAngularVelocity = Vector3.zero
                    end
                end)
                task.wait()
            end
        end)

        -- RenderStepped lock
        local renderConn
        renderConn = RunService.RenderStepped:Connect(function()
            if not Anti.AntiGrabV2 or not BeingHeld.Value then
                renderConn:Disconnect()
                return
            end
            if hrp and lastFreePos then
                hrp.CFrame = lastFreePos
                hrp.AssemblyLinearVelocity = Vector3.zero
                hrp.AssemblyAngularVelocity = Vector3.zero
            end
        end)
    end)
    return conn
end

-- Anti-Grab v3 (BEST)
local function StartAntiGrabV3()
    if not Anti.AntiGrabV3 then return end

    local antiGrabProc = false
    local AGWalk = false

    local function ApplyAntiGrab(char)
        if not char or not Anti.AntiGrabV3 then return end

        local hrp = FWC(char, "HumanoidRootPart", 5)
        local hum = FWC(char, "Humanoid", 5)
        local head = FWC(char, "Head", 5)

        if not (hrp and hum and head) then return end

        -- Desativa constraints iniciais
        for _, v in pairs(char:GetChildren()) do
            if v:IsA("BasePart") and v:FindFirstChild("BallSocketConstraint") and v.Name ~= "Head" then
                v.BallSocketConstraint.Enabled = false
                if v:FindFirstChild("RagdollLimbPart") then
                    v.RagdollLimbPart.WeldConstraint.Enabled = false
                end
            end
        end

        local headConn
        headConn = head.ChildAdded:Connect(function(part)
            if part.Name == "PartOwner" then
                if not antiGrabProc then
                    antiGrabProc = true
                    hum.Sit = false
                    if Struggle then Struggle:FireServer(LocalPlayer) end

                    task.spawn(function()
                        while (head and head:FindFirstChild("PartOwner")) or (BeingHeld and BeingHeld.Value) do
                            if Struggle then Struggle:FireServer(LocalPlayer) end
                            if RagdollRemote and hrp then RagdollRemote:FireServer(hrp, 0) end
                            task.wait()
                        end
                    end)

                    hrp.Anchored = true
                    if not AGWalk then
                        AGWalk = true
                        while BeingHeld and BeingHeld.Value and task.wait() do
                            if hum then
                                hrp.CFrame = hrp.CFrame + hum.MoveDirection * 0.43
                            end
                        end
                    end
                    hrp.Anchored = false
                    antiGrabProc = false
                    AGWalk = false
                end
            end
        end)

        local ragdolled = hum:FindFirstChild("Ragdolled")
        if ragdolled then
            ragdolled.Changed:Connect(function()
                if hum.Ragdolled.Value then
                    for _, v in pairs(char:GetChildren()) do
                        if v:IsA("BasePart") and v:FindFirstChild("BallSocketConstraint") and v.Name ~= "Head" then
                            v.BallSocketConstraint.Enabled = false
                            if v:FindFirstChild("RagdollLimbPart") then
                                v.RagdollLimbPart.WeldConstraint.Enabled = false
                            end
                        end
                    end
                end
            end)
        end

        local weldHRP = hrp:FindFirstChild("WeldHRP")
        if weldHRP then
            weldHRP.Changed:Connect(function()
                if hrp.WeldHRP.Enabled then
                    while not hum.Sit do task.wait() end
                    hum.Sit = false
                    hum.AutoRotate = true
                    hum.HipHeight = 1
                    while hrp.WeldHRP.Enabled and task.wait() do
                        head.CFrame = hrp.CFrame + Vector3.new(0, 1.35, 0)
                    end
                    hum.HipHeight = 0
                end
            end)
        end

        return headConn
    end

    local conn
    conn = LocalPlayer.CharacterAdded:Connect(function(char)
        task.wait(0.5)
        if Anti.AntiGrabV3 then
            ApplyAntiGrab(char)
        end
    end)

    if LocalPlayer.Character then
        ApplyAntiGrab(LocalPlayer.Character)
    end

    return conn
end

