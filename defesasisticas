local function SetInputLagItem(itemName)
    if inputLagItems[itemName] then
        Config.SelectedInputItem = itemName
        currentInputItem = inputLagItems[itemName]
        Notify("AntiInputLag", string.format("Item alterado para: %s", itemName), 2)
        
        -- Reinicia se estiver ativo
        if Config.AntiInputLagEnabled then
            StopAntiInputLag()
            task.wait(0.1)
            StartAntiInputLag()
        end
    end
end

local function StartAntiInputLag()
    if Config.AntiInputLagEnabled then return end
    Config.AntiInputLagEnabled = true
    
    currentInputItem = inputLagItems[Config.SelectedInputItem] or "FoodHamburger"
    
    antiInputLagTask = task.spawn(function()
        local plr = LocalPlayer
        local char = plr.Character or plr.CharacterAdded:Wait()
        local hrp = char:WaitForChild("HumanoidRootPart")
        local SpawnRemote = ReplicatedStorage.MenuToys.SpawnToyRemoteFunction
        local DestroyToyRemote = ReplicatedStorage.MenuToys.DestroyToy
        
        while Config.AntiInputLagEnabled do
            local toysFolder = GetToysFolder()
            if not toysFolder then
                task.wait(0.1)
                continue
            end
            
            local toy = toysFolder:FindFirstChild(currentInputItem)
            
            if not toy then
                pcall(function()
                    SpawnRemote:InvokeServer(currentInputItem, 
                        hrp.CFrame * CFrame.new(0, 5, 0), 
                        Vector3.zero)
                end)
                
                local t0 = tick()
                repeat
                    RunService.Heartbeat:Wait()
                    toysFolder = GetToysFolder()
                    toy = toysFolder and toysFolder:FindFirstChild(currentInputItem)
                until toy or tick() - t0 > 1 or not Config.AntiInputLagEnabled
            end
            
            if toy and toy.Parent then
                local holdPart = toy:FindFirstChild("HoldPart")
                if holdPart then
                    local holdingPlayer = holdPart:FindFirstChild("HoldingPlayer")
                    holdingPlayer = holdingPlayer and holdingPlayer.Value
                    
                    if holdingPlayer and holdingPlayer ~= plr then
                        pcall(function()
                            holdPart.DropItemRemoteFunction:InvokeServer(
                                toy, 
                                hrp.CFrame * CFrame.new(0, Config.InputLagHeight, 0),
                                Vector3.zero
                            )
                        end)
                        pcall(function() DestroyToyRemote:FireServer(toy) end)
                    else
                        pcall(function()
                            holdPart.HoldItemRemoteFunction:InvokeServer(toy, char)
                        end)
                        task.wait(Config.InputLagDelay)
                        
                        pcall(function()
                            holdPart.DropItemRemoteFunction:InvokeServer(
                                toy,
                                hrp.CFrame * CFrame.new(0, Config.InputLagHeight, 0),
                                Vector3.zero
                            )
                        end)
                        task.wait(0.01)
                    end
                end
            end
            
            RunService.Heartbeat:Wait()
        end
    end)
end

local function StopAntiInputLag()
    Config.AntiInputLagEnabled = false
    if antiInputLagTask then
        task.cancel(antiInputLagTask)
        antiInputLagTask = nil
    end
end

