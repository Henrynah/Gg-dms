-- 7. ANTI EXPLOSION
-- ============================================================
local function StartAntiExplosion()
    if Config.AntiExplosionEnabled then return end
    Config.AntiExplosionEnabled = true
    
    local char = GetCharacter()
    if not char then return end
    local hrp = GetHumanoidRootPart()
    if not hrp then return end
    
    antiExplosionConnection = Workspace.ChildAdded:Connect(function(model)
        if model.Name == "Part" and Config.AntiExplosionEnabled then
            local mag = (model.Position - hrp.Position).Magnitude
            if mag <= Config.ExplosionRadius then
                hrp.Anchored = true
                task.wait(0.01)
                
                local rightArm = char:FindFirstChild("Right Arm")
                if rightArm then
                    local ragdollPart = rightArm:FindFirstChild("RagdollLimbPart")
                    if ragdollPart then
                        while ragdollPart.CanCollide and Config.AntiExplosionEnabled do
                            task.wait(0.001)
                        end
                    end
                end
                
                if Config.AntiExplosionEnabled then
                    hrp.Anchored = false
                end
            end
        end
    end)
end

local function StopAntiExplosion()
    Config.AntiExplosionEnabled = false
    if antiExplosionConnection then
        antiExplosionConnection:Disconnect()
        antiExplosionConnection = nil
    end
end

