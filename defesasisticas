-- Gucci Anti-Grab (Blobman)
local function StartGucciAntiGrab()
    if not Anti.AntiGrabGucci then return end

    local spawnBlobman = function()
        local args = {"CreatureBlobman", CFrame.new(0, 5000000, 0), Vector3.new(0, 60, 0)}
        pcall(function() SpawnToyRemote:InvokeServer(unpack(args)) end)

        local folder = Workspace:WaitForChild(LocalPlayer.Name .. "SpawnedInToys", 5)
        if folder and folder:FindFirstChild("CreatureBlobman") then
            local blob = folder.CreatureBlobman
            if blob:FindFirstChild("Head") then
                blob.Head.CFrame = CFrame.new(0, 50000, 0)
                blob.Head.Anchored = true
            end
            return blob
        end
        return nil
    end

    local startGucci = function()
        local char = GetCharacter()
        local hum = GetHumanoid()
        local hrp = GetHRP()

        if not (char and hum and hrp) then return end

        local safePos = hrp.Position
        local folder = Workspace:FindFirstChild(LocalPlayer.Name .. "SpawnedInToys")
        local blob = folder and folder:FindFirstChild("CreatureBlobman")
        local seat = blob and blob:FindFirstChild("VehicleSeat")

        if not blob then blob = spawnBlobman() end
        if not blob then return end

        seat = blob:FindFirstChild("VehicleSeat")
        if seat and seat:IsA("VehicleSeat") then
            hrp.CFrame = seat.CFrame + Vector3.new(0, 2, 0)
            seat:Sit(hum)
        end

        local restoreFrames = 0
        hum:GetPropertyChangedSignal("Jump"):Connect(function()
            if hum.Jump and hum.Sit then
                restoreFrames = 15
                safePos = hrp.Position
            end
        end)

        local conn
        conn = RunService.Heartbeat:Connect(function()
            if not hrp or not hum then return end
            if RagdollRemote then RagdollRemote:FireServer(hrp, 0) end

            local blobFolder = Workspace:FindFirstChild(LocalPlayer.Name .. "SpawnedInToys")
            local currentBlob = blobFolder and blobFolder:FindFirstChild("CreatureBlobman")
            if currentBlob and currentBlob:FindFirstChild("Head") then
                currentBlob.Head.CFrame = CFrame.new(0, 50000, 0)
                currentBlob.Head.Anchored = true
            end

            if restoreFrames > 0 then
                hrp.CFrame = CFrame.new(safePos)
                restoreFrames = restoreFrames - 1
            end
        end)

        task.spawn(function()
            while hum.Sit do task.wait(1) end
            task.wait(0.5)
            hrp.CFrame = CFrame.new(safePos)
        end)

        return conn
    end

    local stopGucci = function(conn)
        if conn then conn:Disconnect() end
        local folder = Workspace:FindFirstChild(LocalPlayer.Name .. "SpawnedInToys")
        if folder and folder:FindFirstChild("CreatureBlobman") then
            pcall(function() DestroyToy:FireServer(folder.CreatureBlobman) end)
        end
    end

    local conn = startGucci()
    local cleanup = function() stopGucci(conn) end

    return { start = startGucci, stop = cleanup }
end

-- Gucci Anti-Grab (Train)
local function StartGucciTrain()
    if not Anti.AntiGrabGucciTrain then return end

    local char = GetCharacter()
    local hum = GetHumanoid()
    local hrp = GetHRP()

    if not (char and hum and hrp) then return end

    local safePos = hrp.Position
    local folder = workspace.Map.AlwaysHereTweenedObjects
    local train = folder and folder:FindFirstChild("Train")
    local seat

    if train then
        for _, d in ipairs(train:GetDescendants()) do
            if d:IsA("Seat") then seat = d break end
        end
    end

    if seat then
        hrp.CFrame = seat.CFrame + Vector3.new(0, 2, 0)
        seat:Sit(hum)
    end

    local restoreFrames = 0
    hum:GetPropertyChangedSignal("Jump"):Connect(function()
        if hum.Jump and hum.Sit then
            restoreFrames = 15
            safePos = hrp.Position
        end
    end)

    local conn
    conn = RunService.Heartbeat:Connect(function()
        if not hrp or not hum then return end
        if RagdollRemote then RagdollRemote:FireServer(hrp, 0) end
        if restoreFrames > 0 then
            hrp.CFrame = CFrame.new(safePos)
            restoreFrames = restoreFrames - 1
        end
    end)

    task.spawn(function()
        while hum.Sit do task.wait(1) end
        task.wait(0.5)
        hrp.CFrame = CFrame.new(safePos)
    end)

    return conn
end

